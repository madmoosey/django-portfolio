# =============================================================================
# ArborWatch — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in values:
#   cp .env.example .env
# =============================================================================

# --- Django ---
DJANGO_SECRET_KEY=your-secret-key-here-generate-with-python-secrets
DJANGO_DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# --- PostgreSQL ---
POSTGRES_DB=arborwatch
POSTGRES_USER=arborwatch
POSTGRES_PASSWORD=arborwatch
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# --- External APIs ---

# Global Forest Watch Data API
# Signup: https://www.globalforestwatch.org/ → Create account → API Settings
GFW_API_KEY=

# NOAA Climate Data Online
# Signup: https://www.ncdc.noaa.gov/cdo-web/token
NOAA_CDO_TOKEN=

# National Weather Service (no key required, but identify your app)
NWS_USER_AGENT=ArborWatch/1.0 (arborwatch.net)

# --- Flower (Celery monitoring) ---
FLOWER_USER=admin
FLOWER_PASSWORD=admin

# --- Docker Compose Port Overrides ---
WEB_PORT=8000
FLOWER_PORT=5555
REDIS_PORT=6379

# --- AWS (Production only) ---
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
# AWS_STORAGE_BUCKET_NAME=arborwatch-static
# AWS_S3_REGION_NAME=us-east-1
# AWS_S3_CUSTOM_DOMAIN=

# --- Sentry (Production only) ---
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Email (Production only) ---
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=noreply@arborwatch.net

AIRNOW_API_KEY=