[[source]]
url = "https://pypi.org/simple"
verify_ssl = true
name = "pypi"

[packages]
# Django Core
django = ">=5.1,<5.2"
djangorestframework = ">=3.15,<3.16"
django-filter = ">=24.3,<25.0"
django-cors-headers = ">=4.4,<5.0"

# Celery & Task Queue
celery = {extras = ["redis"], version = ">=5.4,<5.5"}
django-celery-beat = ">=2.7,<2.8"
django-celery-results = ">=2.5,<2.6"
flower = ">=2.0,<3.0"

# Database
psycopg2-binary = ">=2.9,<3.0"

# API Documentation
drf-spectacular = ">=0.27,<0.28"

# Geospatial
djangorestframework-gis = ">=1.0,<2.0"

# Redis
redis = ">=5.0,<6.0"
django-redis = ">=5.4,<6.0"

# Utilities
python-decouple = ">=3.8,<4.0"
requests = ">=2.32,<3.0"
httpx = ">=0.27,<0.28"
djangorestframework-csv = "==3.0.2"

# ML & Data Processing
pandas = ">=2.2,<3.0"
numpy = ">=1.26,<2.0"
scikit-learn = ">=1.5,<1.6"
xgboost = ">=2.1,<2.2"
shap = ">=0.46,<0.47"
joblib = ">=1.4,<2.0"

# Production
gunicorn = ">=22.0,<23.0"
boto3 = ">=1.35,<2.0"
django-storages = {extras = ["s3"], version = ">=1.14,<2.0"}
whitenoise = ">=6.7,<7.0"
sentry-sdk = {extras = ["django", "celery"], version = ">=2.13,<3.0"}
django-csp = ">=3.8,<4.0"

[dev-packages]
# Testing
pytest = ">=8.3,<9.0"
pytest-django = ">=4.9,<5.0"
pytest-cov = ">=5.0,<6.0"
pytest-asyncio = ">=0.24,<0.25"
factory-boy = ">=3.3,<4.0"
faker = ">=30.0,<31.0"

# Code Quality
black = ">=24.8,<25.0"
isort = ">=5.13,<6.0"
flake8 = ">=7.1,<8.0"
mypy = ">=1.11,<2.0"
django-stubs = ">=5.0,<6.0"
djangorestframework-stubs = ">=3.15,<4.0"

# Debug
django-debug-toolbar = ">=4.4,<5.0"

# Documentation
sphinx = ">=7.4,<8.0"

[requires]
python_version = "3.12"
